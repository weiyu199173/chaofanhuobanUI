# ====================================================
# Transcend 应用环境变量配置示例
# ====================================================
# 使用方法：复制此文件为 .env 并填入你的实际配置值

# Supabase 项目配置
# 获取方式：登录 Supabase -> 选择项目 -> 设置 -> API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# 注意：
# 1. 不要将 .env 文件提交到 Git 仓库（已在 .gitignore 中配置）
# 2. ANON KEY 是公开的，不包含敏感权限
# 3. 如果需要服务端操作，请使用 SERVICE ROLE KEY（但请不要在前端使用）
